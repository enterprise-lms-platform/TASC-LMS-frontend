# Backend API Configuration
VITE_API_BASE_URL= https://api-staging.tasclms.com/api/schema.json

# Note: Create a .env.local file with these variables for local development
# The .env.local file is gitignored and will not be committed

# Flutterwave Configuration
# Obtain from Flutterwave Dashboard: https://dashboard.flutterwave.com/en/api-keys
# this sandbox not live live. they are acting as placeholder
VITE_FLW_CLIENT_ID=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx
VITE_FLW_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxx
VITE_FLW_CLIENT_SECRET=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx #Will be updated upon review

# Google OAuth Configuration
# Obtain from Google Cloud Console: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# ⚠️ SECURITY: Authentication Bypass (LOCAL DEVELOPMENT ONLY)
# Set to 'true' ONLY in .env.local for local development
# NEVER enable this in production or committed to version control
# Create a .env.local file and add this ONLY for local testing:
# VITE_AUTH_BYPASS=true